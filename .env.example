# APP_SETTINGS
APP_NAME="CRM Finance"
#development instead local for testing
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

#Telescope
TELESCOPE_ENABLED=true

APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# for Docker
LOG_CHANNEL=stderr_json

#for production
#LOG_CHANNEL=single_json

LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SENTRY
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# DB_CONNECTION
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crm_db
DB_USERNAME=crm_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# СACHE_DRIVER - <=11 > - CACHE_STORE
CACHE_STORE=redis

# REDIS_SETTINGS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# QUEUE_SETTINGS
QUEUE_CONNECTION=redis

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CRM SETTINGS
CRM_DEFAULT_CURRENCY=UAH
CRM_MIN_TRANSFER=10
CRM_MAX_TRANSFER=500000
SENTRY_SEND_DEFAULT_PII=true
